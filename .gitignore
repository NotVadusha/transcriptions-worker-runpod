# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
.env.*
!.env.example

# Models / weights / caches
*.pt
*.bin
*.onnx
models/
.cache/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Logs
*.log

# Audio artifacts (downloaded inputs / normalized WAVs / local test clips)
*.wav
*.flac
*.mp3
*.m4a

# Benchmark — local audio + references + run outputs (SPEC §10.4): may contain
# real customer audio; never commit. Keep the directories (via .gitkeep) but
# ignore their contents.
benchmark/datasets/*
benchmark/results/*
!benchmark/datasets/.gitkeep
!benchmark/results/.gitkeep
!benchmark/datasets/README.md
